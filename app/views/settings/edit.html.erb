<% content_for :title, t("settings.title") %>
<div class="container" style="max-width:560px;margin:32px auto">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:24px"><%= t("settings.title") %></h1>

  <%= form_with model: @user, url: settings_path, method: :patch do |f| %>
    <div class="field">
      <%= f.label :name, t("auth.name") %>
      <%= f.text_field :name, class: "input" %>
    </div>
    <div class="field">
      <label><%= t("settings.public_profile") %></label>
      <%= render "shared/copy_field", value: profile_url(@user) %>
    </div>

    <div class="field">
      <%= f.label :username, t("settings.username") %>
      <%= f.text_field :username, class: "input", placeholder: t("settings.username_hint") %>
      <span class="muted" style="font-size:13px"><%= t("settings.username_help") %></span>
    </div>
    <div class="field">
      <%= f.label :bio, t("settings.profile") %>
      <%= f.text_area :bio, class: "input" %>
    </div>
    <div class="field">
      <%= f.label :country, t("settings.country") %>
      <%= render "shared/combobox", name: "user[country]", options: country_options, selected: @user.country, form: f %>
    </div>
    <div class="field">
      <%= f.label :locale, t("settings.language") %>
      <%= render "shared/combobox", name: "user[locale]", options: available_locales_for_switcher.map { |loc, meta| [meta[:native], loc] }, selected: @user.locale, form: f %>
    </div>
    <fieldset class="field" style="border:0;padding:0;margin:0">
      <legend style="font-weight:600;margin-bottom:8px"><%= t("settings.units") %></legend>
      <% %i[length weight depth].each do |measurement| %>
        <div class="field">
          <%= f.label "#{measurement}_units", t("units.#{measurement}") %>
          <%= f.select "#{measurement}_units",
                User.send("#{measurement}_units").keys.map { |u| [ t("units.#{u}"), u ] },
                { selected: @user.public_send("#{measurement}_units") }, class: "input" %>
        </div>
      <% end %>
    </fieldset>
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
  <% end %>
</div>
