<% content_for :title, t("settings.title") %>
<div class="container" style="max-width:560px;margin:32px auto">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:24px"><%= t("settings.title") %></h1>

  <%= form_with model: @user, url: settings_path, method: :patch do |f| %>
    <div class="field">
      <%= f.label :name, t("auth.name") %>
      <%= f.text_field :name, class: "input" %>
    </div>
    <div class="field">
      <%= f.label :bio, t("settings.profile") %>
      <%= f.text_area :bio, class: "input" %>
    </div>
    <div class="field">
      <%= f.label :country, t("settings.country") %>
      <%= render "shared/combobox", name: "user[country]", options: country_options, selected: @user.country, form: f %>
    </div>
    <div class="field">
      <%= f.label :locale, t("settings.language") %>
      <%= render "shared/combobox", name: "user[locale]", options: available_locales_for_switcher.map { |loc, meta| [meta[:native], loc] }, selected: @user.locale, form: f %>
    </div>
    <div class="field">
      <%= f.label :units, t("settings.units") %>
      <%= f.select :units, User.units.keys.map { |u| [t("units.#{u}"), u] }, { selected: @user.units }, class: "input" %>
    </div>
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
    <%= button_to t("auth.sign_out"), session_path, method: :delete, class: "btn", style: "margin-left:8px" %>
  <% end %>
</div>
