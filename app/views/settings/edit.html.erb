<% content_for :title, t("settings.title") %>
<div class="container" style="max-width:560px;margin:32px auto">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:24px"><%= t("settings.title") %></h1>
  <%= render "settings/account", user: @user %>

  <h2 style="font-size:20px;font-weight:700;letter-spacing:-.02em;margin:36px 0 16px"><%= t("settings.tab_preferences") %></h2>
  <%= render "settings/preferences", user: @user %>

  <h2 style="font-size:20px;font-weight:700;letter-spacing:-.02em;margin:36px 0 16px"><%= @user.password_set? ? t("settings.change_password") : t("settings.set_password") %></h2>
  <%= render "settings/password", user: @user %>
</div>
