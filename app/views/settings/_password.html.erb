<%# locals: user %>
<% unless user.password_set? %>
  <p class="muted" style="margin-bottom:16px;font-size:14px"><%= t("settings.set_password_help") %></p>
<% end %>

<%= form_with model: user, url: password_settings_path, method: :patch do |f| %>
  <% if user.password_set? %>
    <div class="field">
      <%= label_tag "user_current_password", t("settings.current_password") %>
      <%= password_field_tag "user[current_password]", nil, id: "user_current_password", class: "input", autocomplete: "current-password", maxlength: 72 %>
    </div>
  <% end %>
  <div class="field">
    <%= f.label :password, t("settings.new_password") %>
    <%= f.password_field :password, class: "input", autocomplete: "new-password", maxlength: 72 %>
  </div>
  <div class="field">
    <%= f.label :password_confirmation, t("auth.password_confirmation") %>
    <%= f.password_field :password_confirmation, class: "input", autocomplete: "new-password", maxlength: 72 %>
  </div>
  <%= f.submit t("common.save"), class: "btn btn-primary" %>
<% end %>
