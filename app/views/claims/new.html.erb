<% content_for :title, @claimable ? t("claim.title", name: @claimable.name) : t("claim.page_title") %>
<div class="container" style="max-width:600px;margin:32px auto">
  <% unless @claimable %>
    <h1 style="font-size:24px;font-weight:700;margin-bottom:12px"><%= @type == "brand" ? t("brand.claim") : t("shop.claim") %></h1>
    <p class="muted"><%= t("claim.intro", kind: @type) %></p>
    <p style="margin-top:16px"><%= link_to (@type == "brand" ? t("nav.brands") : t("nav.shops")), (@type == "brand" ? brands_path : shops_path), class: "btn" %></p>
  <% else %>
    <% name = @claimable.try(:name) %>
    <h1 style="font-size:24px;font-weight:700;letter-spacing:-.02em;margin-bottom:6px"><%= t("claim.title", name: name) %></h1>
    <p class="muted" style="margin-bottom:24px"><%= t("claim.intro", kind: @type) %></p>

    <% if @claim.persisted? && @claim.status_verified? %>
      <div class="empty-state" style="border-color:var(--ok-border);background:var(--ok-bg)">
        <h3 style="color:var(--ok)"><%= t("claim.verified_title") %></h3>
        <p><%= t("claim.verified_body") %></p>
        <%= link_to name, (@type == "brand" ? brand_path(@claimable) : shop_path(@claimable)), class: "btn" %>
      </div>
    <% elsif @claim.persisted? && @claim.status_rejected? %>
      <div class="empty-state">
        <h3><%= t("claim.rejected_title") %></h3>
        <p><%= t("claim.rejected_body") %></p>
      </div>
    <% elsif @claim.persisted? %>
      <div class="empty-state">
        <h3><%= t("claim.submitted_title") %></h3>
        <p><%= t("claim.submitted_body") %></p>
        <%= link_to name, (@type == "brand" ? brand_path(@claimable) : shop_path(@claimable)), class: "btn" %>
      </div>
    <% else %>
      <%= form_with model: @claim, url: claims_path, method: :post do |f| %>
        <%= hidden_field_tag "claim[type]", @type %>
        <%= hidden_field_tag :slug, @claimable.slug %>
        <div class="field">
          <%= f.label :email, t("auth.email") %>
          <%= f.email_field :email, class: "input", required: true %>
        </div>
        <div class="field">
          <%= f.label :message, t("claim.message_label") %>
          <%= f.text_area :message, class: "input", rows: 5, required: true, placeholder: t("claim.message_hint") %>
        </div>
        <%= f.submit t("claim.submit"), class: "btn btn-primary" %>
      <% end %>
    <% end %>
  <% end %>
</div>
