<% content_for :title, t("moderation.title") %>
<div class="container">
  <div class="page-head">
    <div>
      <h1><%= t("moderation.title") %></h1>
      <div class="sub">
        <%= t("moderation.subtitle") %>
        <% unless current_user.admin? %><span class="role-badge role-moderator" style="margin-left:8px"><%= t("moderation.moderator_view") %></span><% end %>
      </div>
    </div>
    <span class="muted"><%= t("moderation.awaiting", count: @pending_total) %></span>
  </div>

  <!-- Filter chips -->
  <div class="chips" style="margin-bottom:18px">
    <%= link_to t("moderation.all"), moderation_index_path, class: "chip #{'active' unless @filter}" %>
    <% ModerationItem.kinds.keys.each do |kind| %>
      <%= link_to "#{t("moderation.kind.#{kind}")} (#{@counts[kind] || 0})", moderation_index_path(filter: kind), class: "chip #{'active' if @filter == kind}" %>
    <% end %>
  </div>

  <div class="stack" style="gap:10px">
    <% @items.each do |item| %>
      <div class="card card-pad row" style="justify-content:space-between;gap:12px;flex-wrap:wrap">
        <div class="stack" style="gap:6px;min-width:0">
          <div class="row" style="gap:8px">
            <span class="badge-kind <%= moderation_kind_class(item.kind) %>"><%= t("moderation.kind.#{item.kind}") %></span>
            <% if item.status_approved? %><span class="role-badge role-moderator"><%= t("moderation.approved") %></span><% end %>
            <% if item.status_rejected? %><span class="role-badge role-member" style="color:var(--danger)"><%= t("moderation.rejected") %></span><% end %>
          </div>
          <strong style="font-size:15px"><%= moderation_title(item) %></strong>
          <div class="muted" style="font-size:12.5px"><%= t("moderation.submitted_by") %> <%= item.submitter&.name || "—" %> · <%= time_ago_in_words(item.created_at) %></div>
          <% if item.revision&.edit? %>
            <div style="margin-top:8px;width:100%"><%= render "shared/diff", revision: item.revision %></div>
          <% end %>
        </div>
        <div class="row" style="gap:8px">
          <% if item.status_pending? %>
            <% if item.actionable_by?(current_user) %>
              <%= button_to t("moderation.approve"), moderation_path(item, decision: "approve", filter: @filter), method: :patch, class: "btn btn-sm btn-primary" %>
              <%= button_to t("moderation.reject"), moderation_path(item, decision: "reject", filter: @filter), method: :patch, class: "btn btn-sm" %>
            <% else %>
              <span class="badge badge-noproof"><%= t("moderation.needs_admin") %></span>
            <% end %>
          <% else %>
            <%= button_to t("moderation.undo"), moderation_path(item, decision: "undo", filter: @filter), method: :patch, class: "btn btn-sm" %>
          <% end %>
        </div>
      </div>
    <% end %>
    <% if @items.empty? %><div class="empty-state"><p><%= t("moderation.awaiting", count: 0) %></p></div><% end %>
  </div>
</div>
