<%# locals: favoritable, icon_only: false %>
<% icon_only = local_assigns.fetch(:icon_only, false) %>
<% if can_contribute?(:favorites) %>
  <% if favoritable.favorited_by?(current_user) %>
    <%= button_to favorites_path(favoritable_type: favoritable.class.name, favoritable_id: favoritable.id),
          method: :delete, class: "btn btn-fav is-fav#{' btn-fav-icon' if icon_only}",
          title: t("favorites.favorited"), aria: { label: t("favorites.favorited") } do %>
      ★<%= " #{t("favorites.favorited")}" unless icon_only %>
    <% end %>
  <% else %>
    <%= button_to favorites_path(favoritable_type: favoritable.class.name, favoritable_id: favoritable.id),
          method: :post, class: "btn btn-fav#{' btn-fav-icon' if icon_only}",
          title: t("favorites.add"), aria: { label: t("favorites.add") } do %>
      ☆<%= " #{t("favorites.add")}" unless icon_only %>
    <% end %>
  <% end %>
<% elsif !signed_in? %>
  <%= link_to (icon_only ? "☆" : "☆ #{t('favorites.add')}"), new_session_path,
        class: "btn btn-fav#{' btn-fav-icon' if icon_only}", title: t("favorites.add"),
        aria: { label: t("favorites.add") } %>
<% end %>
