<%# locals: f, record — crop + tile-background tools for the record's photo.
    Renders the editor for an attached photo; for a freshly selected file the
    controller points the stage at the local file (object URL) and opens the
    editor, so the image can be processed before it is uploaded. %>
<% attached = record.photo.attached? %>
<% detected = attached ? photo_background_color(record.photo) : nil %>
<div class="crop-tool" data-controller="image-crop" data-image-crop-detected-value="<%= detected %>"
     style="margin-bottom:10px" <%= "hidden" unless attached %>>
  <%= f.hidden_field :photo_crop_x, data: { image_crop_target: "fieldX" } %>
  <%= f.hidden_field :photo_crop_y, data: { image_crop_target: "fieldY" } %>
  <%= f.hidden_field :photo_crop_w, data: { image_crop_target: "fieldW" } %>
  <%= f.hidden_field :photo_crop_h, data: { image_crop_target: "fieldH" } %>
  <%= f.hidden_field :photo_bg_color, data: { image_crop_target: "bgField" } %>

  <div class="row" style="gap:6px;align-items:center;flex-wrap:wrap">
    <% if attached %>
      <div class="upload-thumb">
        <%= image_tag cropped_photo(record, resize_to_fill: [ 88, 88 ]), alt: "" %>
      </div>
    <% end %>
    <button type="button" class="btn btn-sm" data-action="image-crop#toggle"><%= t("crop.adjust") %></button>
    <span style="flex:1"></span>
    <label class="muted" style="font-size:12px" for="<%= f.object_name %>_photo_bg_color_picker"><%= t("crop.bg_label") %></label>
    <input type="color" class="tile-color-picker" id="<%= f.object_name %>_photo_bg_color_picker"
           value="<%= record.photo_bg_color.presence || detected || "#f4f4f5" %>"
           data-image-crop-target="bgPicker" data-action="input->image-crop#pickColor">
    <button type="button" class="btn btn-sm" data-action="image-crop#startSample" title="<%= t("crop.bg_pick") %>" aria-label="<%= t("crop.bg_pick") %>">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m2 22 1-1h3l9-9"/><path d="M3 21v-3l9-9"/><path d="m15 6 3.4-3.4a2.1 2.1 0 1 1 3 3L18 9l.4.4a2.1 2.1 0 1 1-3 3l-3.8-3.8a2.1 2.1 0 1 1 3-3l.4.4Z"/></svg>
    </button>
    <button type="button" class="btn btn-sm" data-image-crop-target="bgAuto" data-action="image-crop#autoColor" <%= "hidden" if record.photo_bg_color.blank? %>><%= t("crop.bg_auto") %></button>
  </div>

  <div class="crop-editor" data-image-crop-target="editor" hidden>
    <div class="crop-stage" data-image-crop-target="stage" data-action="click->image-crop#stageClick">
      <%# The ORIGINAL image, not a resized variant: the controller's pixel math
          relies on naturalWidth matching the stored file's dimensions. %>
      <img src="<%= url_for(record.photo) if attached %>" data-image-crop-target="image" draggable="false" alt="">
      <div class="crop-box" data-image-crop-target="box" data-action="pointerdown->image-crop#startMove">
        <% %w[nw ne sw se].each do |corner| %>
          <span class="crop-handle crop-handle-<%= corner %>" data-handle="<%= corner %>" data-action="pointerdown->image-crop#startResize"></span>
        <% end %>
      </div>
    </div>
    <div class="row crop-actions" style="gap:6px;align-items:center;margin-top:10px;flex-wrap:wrap">
      <button type="button" class="btn btn-sm" data-image-crop-target="aspect" data-aspect="" data-action="image-crop#setAspect"><%= t("crop.aspect_free") %></button>
      <button type="button" class="btn btn-sm" data-image-crop-target="aspect" data-aspect="1" data-action="image-crop#setAspect"><%= t("crop.aspect_square") %></button>
      <span style="flex:1"></span>
      <button type="button" class="btn btn-sm" data-action="image-crop#reset"><%= t("crop.reset") %></button>
      <button type="button" class="btn btn-sm btn-primary" data-action="image-crop#close"><%= t("crop.done") %></button>
    </div>
    <p class="muted" style="font-size:12px;margin-top:6px"><%= t("crop.hint") %></p>
  </div>
</div>
