<%#
  Card-shaped "log a catch" call to action, sized to drop into a .grid-catches
  grid alongside catch cards.
  locals: prefill (hash of new_catch_path query params, optional),
          label (string, optional)
%>
<% prefill = local_assigns.fetch(:prefill, {}) %>
<% label = local_assigns.fetch(:label, t("catch.add_title")) %>
<%= link_to(signed_in? ? new_catch_path(prefill) : new_session_path, class: "card add-card") do %>
  <span class="add-card-plus" aria-hidden="true">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14"></path></svg>
  </span>
  <span class="add-card-label"><%= label %></span>
<% end %>
