<%# Social sign-in buttons. Renders only the providers with credentials configured
    (see ApplicationHelper#oauth_provider_enabled?). Each button POSTs to the
    OmniAuth request phase; omniauth-rails_csrf_protection verifies the token that
    button_to includes. The callback path is locale-independent, so a literal
    string URL is used rather than a route helper. %>
<% if any_oauth_enabled? %>
  <div class="oauth-buttons">
    <% if oauth_provider_enabled?(:google) %>
      <%= button_to "/auth/google_oauth2", method: :post, class: "btn btn-block btn-oauth", data: { turbo: false } do %>
        <svg viewBox="0 0 18 18" aria-hidden="true"><path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.92c1.7-1.57 2.68-3.88 2.68-6.62z"/><path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.26c-.8.54-1.84.86-3.04.86-2.34 0-4.32-1.58-5.02-3.7H.96v2.34A9 9 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.98 10.72a5.4 5.4 0 0 1 0-3.44V4.94H.96a9 9 0 0 0 0 8.12l3.02-2.34z"/><path fill="#EA4335" d="M9 3.58c1.32 0 2.5.46 3.44 1.35l2.58-2.58C13.46.9 11.42 0 9 0A9 9 0 0 0 .96 4.94l3.02 2.34C4.68 5.16 6.66 3.58 9 3.58z"/></svg>
        <%= t("auth.continue_with_google") %>
      <% end %>
    <% end %>
    <% if oauth_provider_enabled?(:apple) %>
      <%= button_to "/auth/apple", method: :post, class: "btn btn-block btn-oauth btn-apple", data: { turbo: false } do %>
        <svg viewBox="0 0 18 18" aria-hidden="true" fill="currentColor"><path d="M12.32 9.53c-.02-1.86 1.52-2.75 1.59-2.8-.87-1.27-2.22-1.44-2.7-1.46-1.15-.12-2.24.68-2.82.68-.58 0-1.48-.66-2.43-.64-1.25.02-2.4.73-3.05 1.85-1.3 2.25-.33 5.58.93 7.4.62.9 1.35 1.9 2.31 1.86.93-.04 1.28-.6 2.4-.6 1.12 0 1.44.6 2.42.58 1-.02 1.63-.91 2.24-1.81.71-1.04 1-2.05 1.02-2.1-.02-.01-1.94-.75-1.96-2.96zM10.5 3.6c.51-.62.86-1.48.76-2.35-.74.03-1.64.5-2.17 1.11-.47.55-.89 1.43-.78 2.28.83.06 1.67-.42 2.19-1.04z"/></svg>
        <%= t("auth.continue_with_apple") %>
      <% end %>
    <% end %>
  </div>

  <div class="or-divider"><%= t("auth.or") %></div>
<% end %>
