<%# locals: changeset, field, label -%>
<%# Per-locale old/new rows for a locale-keyed JSON field (local_names,
    local_descriptions). Renders nothing when the field didn't change. %>
<% if diff_changed?(changeset, field) %>
  <% old_values, new_values = changeset[field.to_s] %>
  <div class="stack" style="gap:4px">
    <div class="filter-label"><%= label %></div>
    <% ((old_values || {}).keys | (new_values || {}).keys).each do |loc| %>
      <% was = (old_values || {})[loc].to_s; now = (new_values || {})[loc].to_s %>
      <% next if was == now %>
      <div style="font-size:13px">
        <span class="muted"><%= loc %>:</span>
        <% if was.present? %><span class="diff-old"><%= was %></span><% end %>
        <% if now.present? %><span class="diff-new"><%= now %></span><% end %>
      </div>
    <% end %>
  </div>
<% end %>
