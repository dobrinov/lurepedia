<%#
  Country multi-select. Builds flag-tagged options and delegates to the generic
  shared/multiselect control; the chosen ISO codes submit as a comma-separated
  string under `name` (e.g. "US,CA,GB").
  locals: name (form field name), selected (array of codes), placeholder (optional)
%>
<% selected = Array(local_assigns.fetch(:selected, [])).map { |c| c.to_s.upcase } %>
<% options = country_options.map { |label, code|
     { value: code, label: label, flag: (flag_available?(code.downcase) ? image_path("flags/#{code.downcase}.svg") : nil) }
   } %>
<%= render "shared/multiselect", name: name, options: options, selected: selected,
      placeholder: local_assigns.fetch(:placeholder, t("shop.add_country")) %>
