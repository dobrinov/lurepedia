<%# locals: rows, metric (symbol). Optional: compact %>
<% if rows.any? %>
  <div class="card" style="overflow-x:auto">
    <table class="lb-table">
      <thead>
        <tr>
          <th><%= t("leaderboard.rank") %></th>
          <th><%= t("leaderboard.angler") %></th>
          <th class="<%= 'metric-active' if metric == :catches %>"><%= t("leaderboard.catches") %></th>
          <th class="<%= 'metric-active' if metric == :upvotes %>"><%= t("leaderboard.upvotes") %></th>
          <th class="<%= 'metric-active' if metric == :length %>"><%= t("leaderboard.best_length") %></th>
        </tr>
      </thead>
      <tbody>
        <% rows.each_with_index do |row, i| %>
          <tr class="<%= 'you' if signed_in? && row.user == current_user %>">
            <td>
              <% if i < 3 %><span class="rank-medal rank-<%= i + 1 %>"><%= i + 1 %></span><% else %><span class="muted"><%= i + 1 %></span><% end %>
            </td>
            <td>
              <span class="row" style="gap:8px">
                <%= country_flag(row.user.country, size: 18) %>
                <span style="font-weight:600"><%= row.user.name %></span>
                <% if signed_in? && row.user == current_user %><span class="role-badge role-admin"><%= t("leaderboard.you") %></span><% end %>
              </span>
            </td>
            <td class="<%= 'metric-active' if metric == :catches %>"><%= row.catches %></td>
            <td class="<%= 'metric-active' if metric == :upvotes %>"><%= row.upvotes %></td>
            <td class="<%= 'metric-active' if metric == :length %>"><%= row.best_length_cm ? fmt_length(row.best_length_cm) : t("common.none") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="empty-state"><p><%= t("leaderboard.empty") %></p></div>
<% end %>
