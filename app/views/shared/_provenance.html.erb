<%# locals: subject (responds to :revisions, optionally :claim/:claimed?) %>
<%
  revisions = subject.revisions.newest_first.to_a
  creator_rev = subject.revisions.chronological.first
  creator = creator_rev&.user
  claim = subject.respond_to?(:claim) ? subject.claim : nil
  owned = claim&.status_verified?
  primary_user = owned ? claim.user : creator
  primary_name = primary_user&.name || "—"
  primary_initials = primary_user&.initials || "?"
%>
<div class="card">
  <div class="card-pad row" style="justify-content:space-between;border-bottom:1px solid var(--surface-2)">
    <strong style="font-size:14px"><%= t("provenance.title") %></strong>
    <span class="muted" style="font-size:12px"><%= t("provenance.edits", count: revisions.size) %></span>
  </div>
  <div class="card-pad row" style="gap:11px;border-bottom:1px solid var(--surface-2)">
    <span class="avatar" style="background:<%= owned ? 'var(--ink)' : 'var(--line)' %>;color:<%= owned ? 'var(--surface-1)' : 'var(--ink-2)' %>"><%= primary_user ? user_avatar(primary_user) : primary_initials %></span>
    <div style="min-width:0;flex:1">
      <div class="row" style="gap:6px">
        <span class="muted" style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.04em"><%= owned ? t("provenance.owned_by") : t("provenance.added_by") %></span>
        <% if owned %><span class="badge-ok role-badge"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.2"><path d="M20 6 9 17l-5-5"></path></svg><%= t("common.verified") %></span><% end %>
      </div>
      <div style="font-size:14px;font-weight:600"><%= primary_name %></div>
      <% if owned && claim.email.present? %><div class="muted" style="font-size:12px"><%= claim.email %></div><% end %>
    </div>
  </div>
  <% if owned && creator %>
    <div class="card-pad muted" style="font-size:12.5px;border-bottom:1px solid var(--surface-2)">
      <%= t("provenance.originally_added", name: creator.name, date: l(creator_rev.created_at.to_date, format: :long)) %>
    </div>
  <% end %>
  <div class="card-pad">
    <div class="muted" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:12px"><%= t("provenance.edit_history") %></div>
    <div class="stack" style="gap:14px">
      <% revisions.each_with_index do |rev, i| %>
        <div class="row" style="gap:11px;align-items:flex-start">
          <span style="width:9px;height:9px;border-radius:999px;background:<%= i.zero? ? 'var(--ink)' : 'var(--line-strong)' %>;margin-top:5px;flex-shrink:0"></span>
          <div>
            <div style="font-size:13px"><%= rev.summary %></div>
            <div class="muted" style="font-size:12px"><%= rev.user&.name || "—" %> · <%= l(rev.created_at.to_date, format: :long) %></div>
          </div>
        </div>
      <% end %>
      <% if revisions.empty? %><div class="muted" style="font-size:13px"><%= t("provenance.created") %></div><% end %>
    </div>
  </div>
</div>
