<%# A plain on-page name search: submits GET ?q= back to the catalog index. %>
<div class="site-search page-search">
  <span class="search-icon">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
  </span>
  <%= form_with url: url, method: :get do |f| %>
    <%= f.search_field :q, value: params[:q], placeholder: placeholder, autocomplete: "off" %>
  <% end %>
</div>
