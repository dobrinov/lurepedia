<% content_for :title, t("admin.activity") %>
<div class="container">
  <%= render "admin/nav" %>

  <div class="card card-pad">
    <div class="stack" style="gap:12px">
      <% @revisions.each do |rev| %>
        <div class="row" style="gap:11px;align-items:flex-start;border-bottom:1px solid var(--surface-2);padding-bottom:10px">
          <span class="avatar" style="background:var(--surface-2);color:var(--ink-2)"><%= rev.user ? user_avatar(rev.user) : "?" %></span>
          <div>
            <div style="font-size:14px"><strong><%= rev.user&.name || "—" %></strong> — <%= rev.summary %></div>
            <div class="muted" style="font-size:12px"><%= rev.subject_type %> · <%= time_ago_in_words(rev.created_at) %></div>
          </div>
        </div>
      <% end %>
      <% if @revisions.empty? %><p class="muted"><%= t("admin.activity") %> —</p><% end %>
    </div>
  </div>
</div>
