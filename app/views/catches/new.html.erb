<% content_for :title, t("catch.add_title") %>
<div class="container" style="max-width:680px;margin:32px auto"
     data-controller="catch-picker"
     data-catch-picker-variations-url-template-value="<%= lure_variation_options_path("__SLUG__") %>"
     data-catch-picker-lure-options-url-value="<%= lure_options_path %>"
     data-catch-picker-lure-slug-value="<%= @selected_lure&.slug %>"
     data-catch-picker-selected-variant-value="<%= @selected_variant&.id %>"
     data-catch-picker-selected-build-value="<%= @selected_build&.id %>"
     data-catch-picker-labels-value="<%= {
       choose_color: t("catch.pick_color"), choose_build: t("catch.pick_build"),
       no_builds: t("catch.no_builds")
     }.to_json %>">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:6px"><%= t("catch.add_title") %></h1>
  <p class="muted" style="margin-bottom:24px"><%= t("contribute.moderation_note") %></p>

  <%= form_with model: @catch, url: catches_path, method: :post do |f| %>
    <div class="field">
      <label><%= t("catch.pick_brand") %></label>
      <%= render "shared/async_combobox",
            name: "brand", url: brand_options_path,
            selected: @selected_brand&.slug, selected_label: @selected_brand&.name,
            placeholder: t("catch.pick_brand"),
            hidden_data: { action: "change->catch-picker#brandChanged" } %>
    </div>

    <div class="field" data-catch-picker-target="lureCombobox">
      <label><%= t("catch.pick_lure") %></label>
      <%= render "shared/async_combobox",
            name: "lure",
            url: @selected_brand ? lure_options_path(brand: @selected_brand.slug) : lure_options_path,
            selected: @selected_lure&.slug, selected_label: @selected_lure&.title,
            placeholder: t("catch.pick_lure"),
            hidden_data: { action: "change->catch-picker#lureChanged" } %>
    </div>

    <div class="row" style="gap:12px">
      <div class="field" style="flex:1">
        <label><%= t("catch.color") %></label>
        <%= select_tag "catch[variant_id]", nil, class: "input", disabled: true,
              data: { catch_picker_target: "colorSelect", action: "change->catch-picker#colorChanged" } %>
      </div>
      <div class="field" style="flex:1">
        <label><%= t("catch.variation") %></label>
        <%= select_tag "catch[build_id]", nil, class: "input", disabled: true,
              data: { catch_picker_target: "buildSelect" } %>
      </div>
    </div>

    <div class="field">
      <label><%= t("catch.pick_species") %></label>
      <%= render "shared/combobox",
            name: "catch[species_id]",
            options: @species.map { |s| [ species_common_name(s), s.id ] },
            selected: @selected_species&.id,
            placeholder: t("catch.pick_species") %>
    </div>

    <div class="field">
      <label><%= t("catch.photos") %></label>
      <div data-controller="image-upload">
        <div class="upload-drop" data-image-upload-target="drop"
             data-action="click->image-upload#browse dragover->image-upload#dragover dragleave->image-upload#dragleave drop->image-upload#drop"><%= t("contribute.add_photos") %></div>
        <%= f.file_field :photos, multiple: true, accept: "image/*", style: "display:none",
              data: { image_upload_target: "input", action: "image-upload#add" } %>
        <div class="upload-previews" data-image-upload-target="previews"></div>
      </div>
    </div>

    <div class="row" style="gap:12px;flex-wrap:wrap">
      <% { season: Catch.seasons, clarity: Catch.clarities, water_body: Catch.water_bodies, wind: Catch.winds, time_of_day: Catch.time_of_days, platform: Catch.platforms, retrieve: Catch.retrieves }.each do |group, enum| %>
        <div class="field" style="flex:1;min-width:180px">
          <%= f.label group, t("condition.#{group}.label") %>
          <%= f.select group, enum.keys.map { |k| [condition_name(group, k), k] }, { include_blank: t("condition.#{group}.any") }, class: "input" %>
        </div>
      <% end %>
    </div>

    <div class="row" style="gap:12px">
      <div class="field" style="flex:1">
        <%= f.label :length_cm, "#{t('catch.length')} (cm)" %>
        <%= f.number_field :length_cm, step: :any, class: "input" %>
      </div>
      <div class="field" style="flex:1">
        <%= f.label :weight_g, "#{t('catch.weight')} (g)" %>
        <%= f.number_field :weight_g, step: :any, class: "input" %>
      </div>
    </div>

    <div class="field">
      <%= f.label :location, t("catch.location") %>
      <%= f.text_field :location, class: "input", placeholder: "Lake Fork, TX" %>
    </div>
    <div class="field">
      <%= f.label :note, t("catch.note") %>
      <%= f.text_area :note, class: "input" %>
    </div>

    <%= f.submit t("common.submit"), class: "btn btn-primary" %>
  <% end %>
</div>
