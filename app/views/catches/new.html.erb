<% content_for :title, t("catch.add_title") %>
<div class="container" style="max-width:680px;margin:32px auto">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:6px"><%= t("catch.add_title") %></h1>
  <p class="muted" style="margin-bottom:24px"><%= t("contribute.moderation_note") %></p>

  <%= form_with model: @catch, url: catches_path, method: :post do |f| %>
    <div class="field">
      <label><%= t("catch.pick_variant") %></label>
      <%= render "shared/combobox",
            name: "catch[variant_id]",
            options: Variant.includes(lure: :brand).map { |v| ["#{v.lure.title} — #{v.name}", v.id] },
            selected: @selected_lure&.variants&.first&.id,
            placeholder: t("catch.pick_lure") %>
    </div>

    <div class="field">
      <label><%= t("catch.pick_species") %></label>
      <%= render "shared/combobox", name: "catch[species_id]", options: @species.map { |s| [s.common_name, s.id] }, placeholder: t("catch.pick_species") %>
    </div>

    <div class="field">
      <label><%= t("catch.photos") %></label>
      <div data-controller="image-upload">
        <div class="upload-drop" data-action="click->image-upload#browse"><%= t("contribute.add_photos") %></div>
        <%= f.file_field :photos, multiple: true, accept: "image/*", style: "display:none",
              data: { image_upload_target: "input", action: "image-upload#add" } %>
        <div class="upload-previews" data-image-upload-target="previews"></div>
      </div>
    </div>

    <div class="row" style="gap:12px;flex-wrap:wrap">
      <% { season: Catch.seasons, clarity: Catch.clarities, water_body: Catch.water_bodies, wind: Catch.winds, time_of_day: Catch.time_of_days, platform: Catch.platforms, retrieve: Catch.retrieves }.each do |group, enum| %>
        <div class="field" style="flex:1;min-width:180px">
          <%= f.label group, t("condition.#{group}.label") %>
          <%= f.select group, enum.keys.map { |k| [condition_name(group, k), k] }, { include_blank: t("condition.#{group}.any") }, class: "input" %>
        </div>
      <% end %>
    </div>

    <div class="row" style="gap:12px">
      <div class="field" style="flex:1">
        <%= f.label :length_cm, "#{t('catch.length')} (cm)" %>
        <%= f.number_field :length_cm, step: :any, class: "input" %>
      </div>
      <div class="field" style="flex:1">
        <%= f.label :weight_g, "#{t('catch.weight')} (g)" %>
        <%= f.number_field :weight_g, step: :any, class: "input" %>
      </div>
    </div>

    <div class="field">
      <%= f.label :location, t("catch.location") %>
      <%= f.text_field :location, class: "input", placeholder: "Lake Fork, TX" %>
    </div>
    <div class="field">
      <%= f.label :note, t("catch.note") %>
      <%= f.text_area :note, class: "input" %>
    </div>

    <%= f.submit t("common.submit"), class: "btn btn-primary" %>
  <% end %>
</div>
