<%# locals: variant, submit_label %>
<% url = variant.persisted? ? variant_path(@lure, variant) : variants_path(@lure) %>
<%= form_with model: variant, url: url, method: (variant.persisted? ? :patch : :post) do |f| %>
  <div class="field">
    <%= f.label :name, t("lure.color_name") %>
    <%= f.text_field :name, class: "input", required: true %>
  </div>
  <div class="field">
    <%= f.label :best_for, t("lure.best_for") %>
    <%= f.text_field :best_for, class: "input", placeholder: "Largemouth Bass · Clear water" %>
  </div>
  <div class="field">
    <label class="row" style="gap:8px;align-items:center">
      <%= f.check_box :uv_glow %> <%= t("lure.uv_glow") %>
    </label>
  </div>
  <div class="field">
    <%= f.label :photo, t("catch.photos") %>
    <div data-controller="image-upload">
      <% if variant.photo.attached? %>
        <div class="upload-thumb" style="margin-bottom:10px">
          <%= image_tag variant.photo.variant(resize_to_fill: [ 88, 88 ]), alt: variant.name %>
        </div>
      <% end %>
      <div class="upload-drop" data-image-upload-target="drop"
           data-action="click->image-upload#browse dragover->image-upload#dragover dragleave->image-upload#dragleave drop->image-upload#drop">
        <%= t("contribute.add_photos") %>
      </div>
      <%= f.file_field :photo, accept: "image/*", style: "display:none",
            data: { image_upload_target: "input", action: "image-upload#add" } %>
      <div class="upload-previews" data-image-upload-target="previews"></div>
    </div>
  </div>

  <%= f.submit submit_label, class: "btn btn-primary" %>
<% end %>
