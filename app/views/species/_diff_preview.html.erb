<%# locals: record, changeset %>
<% species = record %>
<div class="profile-grid">
  <aside class="profile-aside stack" style="gap:14px">
    <% if diff_changed?(changeset, :photo) %>
      <% new_blob = diff_blob(changeset["photo"][1]); old_blob = diff_blob(changeset["photo"][0]) %>
      <div class="stack" style="gap:8px">
        <div class="card ph ph-lure ph-contain" style="<%= photo_frame_style(new_blob) %>">
          <% if new_blob %>
            <%= image_tag new_blob.variant(resize_to_limit: [ 720, 720 ]), alt: species.common_name %>
          <% else %>
            <%= render "shared/fish_glyph" %>
          <% end %>
        </div>
        <span class="diff-new" style="align-self:flex-start"><%= t("revision.added") %></span>
        <% if old_blob %>
          <div class="row" style="gap:8px;align-items:center">
            <div class="upload-thumb" style="opacity:.55"><%= image_tag old_blob.variant(resize_to_fill: [ 88, 88 ]), alt: "" %></div>
            <span class="diff-old"><%= t("revision.removed") %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="card ph ph-lure ph-contain" style="<%= photo_frame_style(species.photo) %>">
        <% if species.photo.attached? %>
          <%= image_tag cropped_photo(species, resize_to_limit: [ 720, 720 ]), alt: species.common_name %>
        <% else %>
          <%= render "shared/fish_glyph" %>
        <% end %>
      </div>
    <% end %>

    <div class="stack" style="gap:6px">
      <h1 style="font-size:24px;font-weight:700;letter-spacing:-.02em"><%= species.common_name %></h1>
      <div class="muted" style="font-style:italic"><%= diff_field(changeset, species, :scientific_name) %></div>
    </div>

    <div class="chips">
      <span class="tag"><%= diff_field(changeset, species, :water) { |v| water_name(v) } %></span>
      <% %i[venomous poisonous].each do |flag| %>
        <% next unless diff_changed?(changeset, flag) || species.public_send("#{flag}?") %>
        <span class="tag"><%= t("species.#{flag}") %>: <%= diff_field(changeset, species, flag) { |v| v ? t("common.yes") : t("common.no") } %></span>
      <% end %>
    </div>

    <% if species.habitat.present? %><p class="muted"><%= species.habitat %></p><% end %>
    <p class="muted" style="font-size:13px"><%= diff_field(changeset, species, :wikipedia_url) %></p>

    <% { local_names: t("species.local_names"), local_descriptions: t("species.descriptions") }.each do |field, label| %>
      <%= render "shared/locale_hash_diff", changeset: changeset, field: field, label: label %>
    <% end %>
  </aside>
</div>
