<% content_for :title, t("species.add_title") %>
<div class="container" style="max-width:560px;margin:32px auto">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:6px"><%= t("species.add_title") %></h1>
  <p class="muted" style="margin-bottom:24px"><%= t("contribute.moderation_note") %></p>

  <%= form_with model: @species, url: species_index_path, method: :post do |f| %>
    <div class="field">
      <%= f.label :scientific_name, t("species.scientific_name") %>
      <%= f.text_field :scientific_name, class: "input", required: true %>
    </div>
    <div class="field">
      <%= f.label :water, t("lure.water") %>
      <%= f.select :water, Species.waters.keys.map { |w| [water_name(w), w] }, {}, class: "input" %>
    </div>
    <%= f.submit t("common.submit"), class: "btn btn-primary" %>
  <% end %>
</div>
