<%# locals: species, submit_label %>
<%= form_with model: species do |f| %>
  <div class="field">
    <%= f.label :scientific_name, t("species.scientific_name") %>
    <%= f.text_field :scientific_name, class: "input", required: true %>
  </div>
  <div class="field">
    <%= f.label :water, t("lure.water") %>
    <%= f.select :water, Species.waters.keys.map { |w| [water_name(w), w] }, {}, class: "input" %>
  </div>
  <div class="field">
    <label class="toggle"><%= f.check_box :venomous %><span class="track"><span class="knob"></span></span><%= t("species.venomous") %></label>
    <p class="muted" style="font-size:13px;margin-top:4px"><%= t("species.venomous_hint") %></p>
  </div>
  <div class="field">
    <label class="toggle"><%= f.check_box :poisonous %><span class="track"><span class="knob"></span></span><%= t("species.poisonous") %></label>
    <p class="muted" style="font-size:13px;margin-top:4px"><%= t("species.poisonous_hint") %></p>
  </div>
  <div class="field">
    <%= f.label :wikipedia_url, t("species.wikipedia_url") %>
    <%= f.url_field :wikipedia_url, class: "input", placeholder: "https://en.wikipedia.org/wiki/..." %>
  </div>
  <fieldset class="field" style="border:0;padding:0;margin:0">
    <legend style="font-weight:600;margin-bottom:4px"><%= t("species.translations") %></legend>
    <p class="muted" style="font-size:13px;margin-bottom:8px"><%= t("species.translations_hint") %></p>
    <% names = species.local_names || {} %>
    <% descriptions = species.local_descriptions || {} %>
    <div data-controller="tabs">
      <div class="tabs" style="flex-wrap:wrap">
        <% available_locales_for_switcher.each do |loc, meta| %>
          <button type="button" class="tab<%= " active" if loc == I18n.locale %>" data-tab-name="<%= loc %>" data-tabs-target="tab" data-action="tabs#select"><%= meta[:native] %></button>
        <% end %>
      </div>
      <% available_locales_for_switcher.each do |loc, _meta| %>
        <div class="tab-panel<%= " active" if loc == I18n.locale %>" data-tab-panel="<%= loc %>" data-tabs-target="panel">
          <div class="field">
            <%= label_tag "species_local_names_#{loc}", t("species.local_name") %>
            <%= text_field_tag "species[local_names][#{loc}]", names[loc.to_s], id: "species_local_names_#{loc}", class: "input" %>
          </div>
          <div class="field">
            <%= label_tag "species_local_descriptions_#{loc}", t("species.description") %>
            <%= text_area_tag "species[local_descriptions][#{loc}]", descriptions[loc.to_s], id: "species_local_descriptions_#{loc}", class: "input", rows: 4 %>
          </div>
        </div>
      <% end %>
    </div>
  </fieldset>
  <div class="field">
    <%= f.label :photo, t("catch.photos") %>
    <div data-controller="image-upload">
      <% if species.photo.attached? %>
        <div class="upload-thumb" style="margin-bottom:10px">
          <%= image_tag species.photo.variant(resize_to_fill: [ 88, 88 ]), alt: species.common_name %>
        </div>
      <% end %>
      <div class="upload-drop" data-image-upload-target="drop"
           data-action="click->image-upload#browse dragover->image-upload#dragover dragleave->image-upload#dragleave drop->image-upload#drop">
        <%= t("contribute.add_photos") %>
      </div>
      <%= f.file_field :photo, accept: "image/*", style: "display:none",
            data: { image_upload_target: "input", action: "image-upload#add" } %>
      <div class="upload-previews" data-image-upload-target="previews"></div>
    </div>
  </div>
  <%= f.submit submit_label, class: "btn btn-primary" %>
<% end %>
