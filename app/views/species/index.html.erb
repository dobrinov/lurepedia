<% content_for :title, t("species.title") %>
<div class="container">
  <div class="page-head">
    <div>
      <h1><%= t("species.title") %></h1>
    </div>
    <%= link_to t("species.add"), new_species_path, class: "btn btn-sm" %>
  </div>

  <div class="page-search-row">
    <%= render "shared/search_bar", url: species_index_path, placeholder: t("species.search_placeholder") %>
  </div>

  <% if @species.any? %>
    <div class="grid-cards">
      <% @species.each do |sp| %>
        <%= link_to species_path(sp), class: "card" do %>
          <div class="ph ph-lure ph-contain" style="<%= photo_frame_style(sp.photo) %>">
            <% if sp.photo.attached? %>
              <%= image_tag cropped_photo(sp, resize_to_limit: [ 560, 560 ]), alt: sp.common_name, loading: "lazy" %>
            <% else %>
              <%= render "shared/fish_glyph" %>
            <% end %>
          </div>
          <div class="card-body">
            <div class="card-title" style="font-size:16px"><%= sp.common_name %></div>
            <div class="muted" style="font-size:12.5px;font-style:italic"><%= sp.scientific_name %></div>
            <div class="chips" style="margin-top:auto;padding-top:6px">
              <%= render "species/hazard_tags", species: sp %>
              <span class="tag"><%= water_name(sp.water) %></span>
              <span class="tag"><%= t("species.lures_count", count: @proven_lure_counts.fetch(sp.id, 0)) %></span>
              <span class="tag"><%= t("lure.catches_count", count: sp.catches_count) %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
    <%= render "shared/pagination", page: @page %>
  <% elsif @q.present? %>
    <div class="empty-state">
      <h3><%= t("search.no_results") %></h3>
      <%= link_to t("search.clear_all"), species_index_path, class: "btn" %>
    </div>
  <% else %>
    <div class="empty-state">
      <h3><%= t("species.empty_title") %></h3>
      <p><%= t("species.empty_sub") %></p>
      <%= link_to t("species.add"), new_species_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
