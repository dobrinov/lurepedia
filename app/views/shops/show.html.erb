<% content_for :title, @shop.name %>
<% meta_description "#{@shop.name}: #{@shop.blurb.presence || t('meta.shop_show', shop: @shop.name)}" %>

<%= render "shared/pending_review", record: @shop %>

<div class="container" style="padding-top:24px">
  <nav class="muted" style="font-size:13px;margin-bottom:16px">
    <%= link_to t("shop.title"), shops_path %> ›
    <span><%= @shop.name %></span>
  </nav>

  <div class="row" style="justify-content:space-between;align-items:flex-start;margin-bottom:24px;flex-wrap:wrap;gap:16px">
    <div class="stack" style="gap:8px">
      <div class="row" style="gap:8px;align-items:center">
        <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em"><%= @shop.name %></h1>
        <% if @shop.promoted? %><span class="badge badge-promoted"><%= t("common.promoted") %></span><% end %>
        <% if @shop.claimed? %>
          <span class="badge badge-ok"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"></path></svg><%= t("claim.managed_badge") %></span>
        <% end %>
      </div>
      <% if @shop.url.present? %>
        <%= link_to safe_join([ @shop.url, external_link_icon ]), "https://#{@shop.url.sub(%r{\Ahttps?://}, '')}", class: "muted", style: "font-size:14px", target: "_blank", rel: "noopener nofollow" %>
      <% end %>
      <div class="row" style="gap:6px;align-items:center;font-size:13px">
        <span class="muted"><%= t("shop.ships_to") %>:</span>
        <% if @shop.ships_worldwide? %>
          <%= worldwide_flag(size: 18) %><span class="muted"><%= t("shop.worldwide") %></span>
        <% elsif @shop.ships_to_countries.any? %>
          <span class="row" style="gap:5px;flex-wrap:wrap">
            <% @shop.ships_to_countries.each do |code| %><span class="tooltip" data-tooltip="<%= country_name(code) %>" tabindex="0" style="display:inline-flex"><%= country_flag(code, size: 18) %></span><% end %>
          </span>
        <% else %>
          <span class="muted"><%= t("shop.ships_to_unknown") %></span>
        <% end %>
      </div>
      <% if @shop.blurb.present? %><p class="muted" style="max-width:520px;margin-top:4px"><%= @shop.blurb %></p><% end %>
    </div>
    <div class="row">
      <%= render "shared/favorite_button", favoritable: @shop %>
      <% if signed_in? %>
        <%= link_to edit_affordance_label(@shop), edit_shop_path(@shop), class: "btn" %>
        <% unless @shop.claimed? %>
          <%= link_to t("shop.claim"), new_claim_path(type: "shop", slug: @shop.slug), class: "btn" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% tabs = [
       [ t("shop.tab_lures"), shop_path(@shop), @tab == "lures" ],
       [ t("shop.tab_history"), shop_path(@shop, tab: "history"), @tab == "history" ]
     ] %>
  <%= render "shared/tabs", tabs: tabs %>

  <% case @tab %>
  <% when "lures" %>
    <% if @lures.any? %>
      <div class="grid-cards">
        <% @lures.each do |lure| %><%= render "shared/lure_card", lure: lure %><% end %>
      </div>
    <% else %>
      <div class="empty-state"><p><%= t("shop.no_lures") %></p></div>
    <% end %>
  <% when "history" %>
    <%= render "shared/provenance", subject: @shop %>
  <% end %>
</div>
