<%# locals: record, changeset %>
<% shop = record %>
<div class="stack" style="gap:8px">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em"><%= diff_field(changeset, shop, :name) %></h1>
  <div class="muted" style="font-size:14px"><%= diff_field(changeset, shop, :url) %></div>
  <div class="row" style="gap:6px;align-items:center;font-size:13px">
    <span class="muted"><%= t("shop.ships_to") %>:</span>
    <% if diff_changed?(changeset, :ships_worldwide) || diff_changed?(changeset, :ships_to) %>
      <% if diff_changed?(changeset, :ships_worldwide) %>
        <%= diff_field(changeset, shop, :ships_worldwide) { |v| v ? t("shop.worldwide") : t("common.no") } %>
      <% end %>
      <% if diff_changed?(changeset, :ships_to) %>
        <%= diff_field(changeset, shop, :ships_to) %>
      <% end %>
    <% elsif shop.ships_worldwide? %>
      <%= worldwide_flag(size: 18) %><span class="muted"><%= t("shop.worldwide") %></span>
    <% elsif shop.ships_to_countries.any? %>
      <span class="row" style="gap:5px;flex-wrap:wrap">
        <% shop.ships_to_countries.each do |code| %><span class="tooltip" data-tooltip="<%= country_name(code) %>" tabindex="0" style="display:inline-flex"><%= country_flag(code, size: 18) %></span><% end %>
      </span>
    <% else %>
      <span class="muted"><%= t("shop.ships_to_unknown") %></span>
    <% end %>
  </div>
  <p class="muted" style="max-width:520px;margin-top:4px"><%= diff_field(changeset, shop, :blurb) %></p>
</div>
