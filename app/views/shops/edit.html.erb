<% direct = can_edit_directly?(@shop) %>
<% content_for :title, direct ? t("contribute.edit_title", name: @shop.name) : t("contribute.suggest_title", name: @shop.name) %>
<div class="container" style="max-width:560px;margin:32px auto">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:6px">
    <%= direct ? t("contribute.edit_title", name: @shop.name) : t("contribute.suggest_title", name: @shop.name) %>
  </h1>
  <p class="muted" style="margin-bottom:24px"><%= direct ? t("contribute.direct_note") : t("contribute.suggest_note") %></p>
  <%= render "form", shop: @shop, submit_label: direct ? t("common.save") : t("common.submit") %>
</div>
