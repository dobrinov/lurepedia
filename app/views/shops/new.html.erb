<% content_for :title, t("shop.add_title") %>
<div class="container" style="max-width:560px;margin:32px auto">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:6px"><%= t("shop.add_title") %></h1>
  <p class="muted" style="margin-bottom:24px"><%= t("contribute.moderation_note") %></p>

  <%= form_with model: @shop, url: shops_path, method: :post do |f| %>
    <div class="field">
      <%= f.label :name, t("auth.name") %>
      <%= f.text_field :name, class: "input", required: true %>
    </div>
    <div class="field">
      <%= f.label :url, t("brand.website") %>
      <%= f.text_field :url, class: "input", placeholder: "example.com", required: true %>
    </div>
    <div data-controller="ships-worldwide">
      <div class="field">
        <label class="row" style="gap:8px;align-items:center">
          <%= f.check_box :ships_worldwide, data: { ships_worldwide_target: "toggle", action: "ships-worldwide#sync" } %> <%= t("shop.ships_worldwide") %>
        </label>
      </div>
      <div class="field">
        <%= f.label :ships_to, t("shop.ships_to") %>
        <%= f.text_field :ships_to, class: "input", placeholder: "US, CA, GB…", data: { ships_worldwide_target: "countries" } %>
        <p class="muted" style="font-size:12.5px;margin-top:4px"><%= t("shop.ships_to_hint") %></p>
      </div>
    </div>
    <div class="field">
      <%= f.label :blurb, t("shop.title") %>
      <%= f.text_area :blurb, class: "input" %>
    </div>
    <%= f.submit t("common.submit"), class: "btn btn-primary" %>
  <% end %>
</div>
