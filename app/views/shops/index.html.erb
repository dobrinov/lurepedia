<% content_for :title, t("shop.title") %>
<% meta_description t("meta.shops_index") %>
<div class="container">
  <div class="page-head">
    <div>
      <h1><%= t("shop.title") %></h1>
    </div>
    <div class="row">
      <%= link_to t("shop.claim"), new_claim_path(type: "shop"), class: "btn btn-sm" %>
      <%= link_to t("shop.add"), new_shop_path, class: "btn btn-sm" %>
    </div>
  </div>

  <div class="page-search-row">
    <%= render "shared/search_bar", url: shops_path, placeholder: t("shop.search_placeholder") %>
  </div>

  <% if @q.present? && @local_shops.empty? && @other_shops.empty? %>
    <div class="empty-state">
      <h3><%= t("search.no_results") %></h3>
      <%= link_to t("search.clear_all"), shops_path, class: "btn" %>
    </div>
  <% else %>
    <div class="section-head"><h2 style="font-size:16px"><%= t("shop.ships_to_you", country: country_name(@country)) %></h2></div>
    <% if @local_shops.any? %>
      <div class="grid-cards" style="margin-bottom:32px">
        <% @local_shops.each do |shop| %><%= render "shops/shop_row", shop: shop %><% end %>
      </div>
    <% else %>
      <div class="empty-state" style="margin-bottom:32px">
        <p><%= t("shop.none_ship", country: country_name(@country)) %></p>
        <%= link_to t("shop.add"), new_shop_path, class: "btn btn-primary" %>
      </div>
    <% end %>

    <% if @other_shops.any? %>
      <div class="section-head"><h2 style="font-size:16px"><%= t("shop.other_shops") %></h2></div>
      <div class="grid-cards">
        <% @other_shops.each do |shop| %><%= render "shops/shop_row", shop: shop %><% end %>
      </div>
      <%= render "shared/pagination", page: @page %>
    <% end %>
  <% end %>
</div>
