<% content_for :title, t("shop.title") %>
<div class="container">
  <div class="page-head">
    <div>
      <h1><%= t("shop.title") %></h1>
    </div>
    <div class="row">
      <%= link_to t("shop.claim"), new_claim_path(type: "shop"), class: "btn btn-sm" %>
      <%= link_to t("shop.add"), new_shop_path, class: "btn btn-sm" %>
    </div>
  </div>

  <div class="page-search-row">
    <%= render "shared/search_bar", url: shops_path, placeholder: t("shop.search_placeholder") %>
  </div>

  <% if @promoted.empty? && @shops.empty? %>
    <% if @q.present? %>
      <div class="empty-state">
        <h3><%= t("search.no_results") %></h3>
        <%= link_to t("search.clear_all"), shops_path, class: "btn" %>
      </div>
    <% else %>
      <div class="empty-state">
        <h3><%= t("shop.empty_title") %></h3>
        <p><%= t("shop.empty_sub") %></p>
        <%= link_to t("shop.add"), new_shop_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  <% else %>
    <% if @promoted.any? %>
      <div class="section-head"><h2 style="font-size:16px"><%= t("shop.promoted_section") %></h2></div>
      <div class="grid-cards" style="margin-bottom:32px">
        <% @promoted.each do |shop| %><%= render "shops/shop_row", shop: shop %><% end %>
      </div>
    <% end %>

    <% if @shops.any? %>
      <div class="section-head"><h2 style="font-size:16px"><%= t("shop.all_shops") %></h2></div>
      <div class="grid-cards">
        <% @shops.each do |shop| %><%= render "shops/shop_row", shop: shop %><% end %>
      </div>
      <%= render "shared/pagination", page: @page %>
    <% end %>
  <% end %>
</div>
