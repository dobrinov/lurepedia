<%# locals: shop %>
<div class="card card-pad stack" data-controller="dropdown">
  <div class="row" style="justify-content:space-between">
    <div class="stack" style="gap:4px">
      <div class="row" style="gap:8px">
        <span class="card-title" style="font-size:17px"><%= shop.name %></span>
        <% if shop.promoted? %><span class="badge badge-promoted"><%= t("common.promoted") %></span><% end %>
      </div>
      <% if shop.url.present? %><%= link_to shop.url, "https://#{shop.url.sub(%r{\Ahttps?://}, '')}", class: "muted", style: "font-size:13px", target: "_blank", rel: "noopener nofollow" %><% end %>
    </div>
    <%= link_to t("shop.visit"), shop.url.present? ? "https://#{shop.url.sub(%r{\Ahttps?://}, '')}" : "#", class: "btn btn-sm", target: "_blank", rel: "noopener nofollow" %>
    <%= render "shared/favorite_button", favoritable: shop %>
  </div>
  <% if shop.blurb.present? %><p class="muted" style="font-size:13.5px;margin:0"><%= shop.blurb %></p><% end %>
  <div class="row muted" style="justify-content:space-between;font-size:12.5px;border-top:1px solid var(--surface-2);padding-top:10px">
    <span>
      <% if shop.claimed? %>
        <%= t("shop.owned_by") %> <strong><%= shop.name %></strong>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--ok)" stroke-width="3" style="display:inline"><path d="M20 6 9 17l-5-5"></path></svg>
      <% else %>
        <%= t("shop.added_by") %> <strong><%= shop.revisions.chronological.first&.user&.name || "—" %></strong>
      <% end %>
    </span>
    <button class="btn btn-sm" data-action="dropdown#toggle" data-dropdown-target="trigger"><%= t("shop.show_history") %></button>
  </div>
  <div data-dropdown-target="menu" hidden style="position:static;box-shadow:none;border:none;padding:0">
    <%= render "shared/provenance", subject: shop %>
  </div>
</div>
