<%# locals: shop %>
<div class="card card-pad stack">
  <div class="row" style="justify-content:space-between;align-items:flex-start">
    <div class="row" style="gap:8px">
      <%= link_to safe_join([ shop.name, external_link_icon ]), "https://#{shop.url.sub(%r{\Ahttps?://}, '')}", class: "card-title", style: "font-size:17px", target: "_blank", rel: "noopener nofollow" %>
      <% if shop.promoted? %><span class="badge badge-promoted"><%= t("common.promoted") %></span><% end %>
    </div>
    <%= render "shared/favorite_button", favoritable: shop, icon_only: true %>
  </div>
  <div class="row muted" style="gap:6px;align-items:center;font-size:13px;flex-wrap:wrap">
    <span><%= t("shop.ships_to") %>:</span>
    <% if shop.ships_worldwide? %>
      <%= worldwide_flag(size: 18) %><span><%= t("shop.worldwide") %></span>
    <% elsif shop.ships_to_countries.any? %>
      <% shop.ships_to_countries.each do |code| %>
        <span class="tooltip" data-tooltip="<%= country_name(code) %>" tabindex="0" style="display:inline-flex"><%= country_flag(code, size: 18) %></span>
      <% end %>
    <% else %>
      <span><%= t("shop.ships_to_unknown") %></span>
    <% end %>
  </div>
</div>
