<% content_for :title, @brand.name %>
<% content_for :head, tag.meta(name: "description", content: "#{@brand.name}: #{@brand.blurb}".truncate(155)) %>

<div class="container" style="padding-top:24px">
  <div class="row" style="justify-content:space-between;align-items:flex-start;margin-bottom:24px;flex-wrap:wrap;gap:16px">
    <div class="row" style="gap:16px">
      <span class="avatar avatar-lg" style="background:var(--surface-2);color:var(--ink-2)"><%= @brand.initials %></span>
      <div class="stack" style="gap:6px">
        <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em"><%= @brand.name %></h1>
        <div class="row muted" style="gap:8px;font-size:14px">
          <% if @brand.country.present? %><%= country_flag(@brand.country, size: 18) %><span><%= @brand.country %></span><% end %>
          <% if @brand.founded_year %><span>· <%= t("brand.founded") %> <%= @brand.founded_year %></span><% end %>
        </div>
        <% if @brand.blurb.present? %><p class="muted" style="max-width:520px"><%= @brand.blurb %></p><% end %>
      </div>
    </div>
    <div class="row">
      <% if signed_in? %>
        <%= link_to edit_affordance_label, edit_brand_path(@brand), class: "btn" %>
        <% unless @brand.claimed? %>
          <%= link_to t("brand.claim"), new_claim_path(type: "brand", slug: @brand.slug), class: "btn" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% tabs = [
       [ t("brand.tab_lures"), brand_path(@brand), @tab == "lures" ],
       [ t("brand.tab_history"), brand_path(@brand, tab: "history"), @tab == "history" ]
     ] %>
  <%= render "shared/tabs", tabs: tabs %>

  <% case @tab %>
  <% when "lures" %>
    <% if @lures.any? %>
      <div class="grid-cards">
        <% @lures.each do |lure| %><%= render "shared/lure_card", lure: lure %><% end %>
      </div>
    <% else %>
      <div class="empty-state"><p><%= t("lure.no_matches") %></p></div>
    <% end %>
  <% when "history" %>
    <%= render "shared/provenance", subject: @brand %>
  <% end %>
</div>
