<% admin = current_user&.admin? %>
<% content_for :title, admin ? t("contribute.edit_title", name: @brand.name) : t("contribute.suggest_title", name: @brand.name) %>
<div class="container" style="max-width:560px;margin:32px auto">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:6px">
    <%= admin ? t("contribute.edit_title", name: @brand.name) : t("contribute.suggest_title", name: @brand.name) %>
  </h1>
  <p class="muted" style="margin-bottom:24px"><%= admin ? t("admin.title") : t("contribute.suggest_note") %></p>
  <%= render "form", brand: @brand, submit_label: admin ? t("common.save") : t("common.submit") %>
</div>
