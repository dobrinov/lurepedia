<%# locals: record, changeset %>
<% brand = record %>
<div class="row" style="gap:16px">
  <span class="avatar avatar-lg" style="background:var(--surface-2);color:var(--ink-2)"><%= brand.initials %></span>
  <div class="stack" style="gap:6px">
    <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em"><%= diff_field(changeset, brand, :name) %></h1>
    <div class="row muted" style="gap:8px;font-size:14px">
      <span><%= t("brand.country") %>: <%= diff_field(changeset, brand, :country) %></span>
      <span>· <%= t("brand.founded") %> <%= diff_field(changeset, brand, :founded_year) %></span>
    </div>
    <p class="muted" style="max-width:520px"><%= diff_field(changeset, brand, :blurb) %></p>
  </div>
</div>
