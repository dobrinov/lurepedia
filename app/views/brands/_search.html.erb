<%= render layout: "shared/filter_panel",
      locals: { url: brands_path, placeholder: t("brand.search_placeholder") } do %>
  <div>
    <div class="filter-label"><%= t("brand.country") %></div>
    <%= render "shared/combobox", name: "country", options: brand_country_options,
          selected: selected_filter_value(:country), placeholder: t("search.any_country") %>
  </div>
  <div>
    <div class="filter-label"><%= t("search.other") %></div>
    <div class="stack" style="gap:8px">
      <label class="toggle"><%= check_box_tag :claimed, "1", params[:claimed].present? %><span class="track"><span class="knob"></span></span><%= t("claim.managed_badge") %></label>
      <label class="toggle"><%= check_box_tag :proven, "1", params[:proven].present? %><span class="track"><span class="knob"></span></span><%= t("search.proven_only") %></label>
    </div>
  </div>
<% end %>
