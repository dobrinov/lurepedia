<% content_for :title, t("brand.add_title") %>
<div class="container" style="max-width:560px;margin:32px auto">
  <h1 style="font-size:28px;font-weight:700;letter-spacing:-.02em;margin-bottom:6px"><%= t("brand.add_title") %></h1>
  <p class="muted" style="margin-bottom:24px"><%= t("contribute.moderation_note") %></p>

  <%= form_with model: @brand, url: brands_path, method: :post do |f| %>
    <div class="field">
      <%= f.label :name, t("auth.name") %>
      <%= f.text_field :name, class: "input", required: true %>
    </div>
    <div class="field">
      <%= f.label :country, t("brand.country") %>
      <%= f.text_field :country, class: "input", placeholder: "US, JP, DE…" %>
    </div>
    <div class="field">
      <%= f.label :founded_year, t("brand.founded") %>
      <%= f.number_field :founded_year, class: "input" %>
    </div>
    <div class="field">
      <%= f.label :blurb, t("brand.title") %>
      <%= f.text_area :blurb, class: "input" %>
    </div>
    <%= f.submit t("common.submit"), class: "btn btn-primary" %>
  <% end %>
</div>
