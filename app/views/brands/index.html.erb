<% content_for :title, t("brand.title") %>
<% meta_description t("meta.brands_index") %>
<div class="container">
  <div class="page-head">
    <div>
      <h1><%= t("brand.title") %></h1>
    </div>
    <%= link_to t("brand.add"), new_brand_path, class: "btn btn-sm" %>
  </div>

  <div class="page-search-row">
    <%= render "brands/search" %>
  </div>

  <!-- Active filter pills -->
  <% if @filter.active_pills.any? %>
    <div class="chips" style="margin-bottom:18px">
      <% @filter.active_pills.each do |key, label| %>
        <span class="filter-pill"><%= label %>
          <%= link_to "×", url_for(request.query_parameters.except(*BrandFilter.pill_params(key), "page")) %>
        </span>
      <% end %>
      <%= link_to t("search.clear_all"), brands_path, class: "muted", style: "font-size:13px" %>
    </div>
  <% end %>

  <% if @brands.any? %>
    <div class="grid-cards">
      <% @brands.each do |brand| %>
        <%= link_to brand_path(brand), class: "card card-pad stack" do %>
          <div class="row" style="justify-content:space-between">
            <%= render "brands/avatar", brand: brand %>
            <% if brand.claimed? %><span class="badge badge-ok"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"></path></svg><%= t("claim.managed_badge") %></span><% end %>
          </div>
          <div class="card-title" style="font-size:17px"><%= brand.name %></div>
          <div class="row muted" style="gap:8px;font-size:13px">
            <% if brand.country.present? %><%= country_flag(brand.country, size: 18) %><span><%= brand.country %></span><% end %>
            <% if brand.founded_year %><span>· <%= t("brand.founded") %> <%= brand.founded_year %></span><% end %>
          </div>
          <div class="tag" style="align-self:flex-start"><%= t("species.lures_count", count: brand.lures_count) %></div>
        <% end %>
      <% end %>
    </div>
    <%= render "shared/pagination", page: @page %>
  <% elsif @filter.any? %>
    <div class="empty-state">
      <h3><%= t("search.no_results") %></h3>
      <%= link_to t("search.clear_all"), brands_path, class: "btn" %>
    </div>
  <% else %>
    <div class="empty-state">
      <h3><%= t("brand.empty_title") %></h3>
      <p><%= t("brand.empty_sub") %></p>
      <%= link_to t("brand.add"), new_brand_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
