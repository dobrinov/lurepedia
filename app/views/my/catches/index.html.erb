<% content_for :title, t("dashboard.my_catches") %>
<div class="container">
  <div class="page-head">
    <div>
      <h1><%= t("dashboard.my_catches") %></h1>
      <div class="sub"><%= t("dashboard.total_upvotes") %>: <strong><%= @total_upvotes %></strong></div>
    </div>
    <%= link_to t("catch.add_title"), new_catch_path, class: "btn btn-sm" %>
  </div>

  <% if @catches.any? %>
    <div class="grid-catches">
      <% @catches.each do |c| %><%= render "shared/catch_card", catch: c %><% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <p><%= t("dashboard.no_catches") %></p>
      <%= link_to t("catch.add_title"), new_catch_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
