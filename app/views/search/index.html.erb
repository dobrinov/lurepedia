<% content_for :title, t("search.title") %>
<div class="container" style="padding-top:24px">
  <h1 style="font-size:26px;font-weight:700;letter-spacing:-.02em;margin-bottom:8px">
    <%= @q.present? ? t("search.results_for", q: @q) : t("search.title") %>
  </h1>

  <% if @q.blank? %>
    <p class="muted"><%= t("nav.search_placeholder") %></p>
  <% elsif @lures.empty? && @brands.empty? && @species.empty? %>
    <div class="empty-state"><h3><%= t("search.no_results") %></h3></div>
  <% else %>
    <% if @lures.any? %>
      <div class="section-head" style="margin-top:24px"><h2 style="font-size:18px"><%= t("search.section_lures") %> (<%= @lures.size %>)</h2></div>
      <div class="grid-cards"><% @lures.each { |l| %><%= render "shared/lure_card", lure: l %><% } %></div>
    <% end %>

    <% if @species.any? %>
      <div class="section-head" style="margin-top:24px"><h2 style="font-size:18px"><%= t("search.section_species") %> (<%= @species.size %>)</h2></div>
      <div class="chips">
        <% @species.each { |s| %><%= link_to species_common_name(s), species_path(s), class: "chip" %><% } %>
      </div>
    <% end %>

    <% if @brands.any? %>
      <div class="section-head" style="margin-top:24px"><h2 style="font-size:18px"><%= t("search.section_brands") %> (<%= @brands.size %>)</h2></div>
      <div class="chips">
        <% @brands.each { |b| %><%= link_to b.name, brand_path(b), class: "chip" %><% } %>
      </div>
    <% end %>
  <% end %>
</div>
