<div class="site-search" data-controller="header-search">
  <span class="search-icon">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
  </span>
  <%= form_with url: search_path, method: :get, data: { header_search_target: "form" } do |f| %>
    <%= f.search_field :q, value: params[:q], placeholder: t("nav.search_placeholder"),
          autocomplete: "off",
          data: { header_search_target: "input", action: "focus->header-search#expand" } %>
  <% end %>

  <div class="search-panel" data-header-search-target="panel" hidden>
    <div class="row" style="justify-content:space-between">
      <strong style="display:flex;align-items:center;gap:8px">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 4h18l-7 8v6l-4 2v-8z"></path></svg>
        <%= t("search.filters") %>
      </strong>
      <span class="muted" style="font-size:13px"><%= t("search.combine_free") %></span>
    </div>
    <%= form_with url: lures_path, method: :get, class: "filters-form" do %>
      <div class="filters-grid">
        <%# Large collections: server-backed, paginated, infinite-scroll comboboxes %>
        <div>
          <div class="filter-label"><%= t("nav.species") %></div>
          <%= render "shared/async_combobox", name: "species", url: species_options_path,
                selected: selected_filter_value(:species), selected_label: selected_species_label(selected_filter_value(:species)),
                placeholder: t("search.any_species") %>
        </div>
        <div>
          <div class="filter-label"><%= t("lure.brand") %></div>
          <%= render "shared/async_combobox", name: "brand", url: brand_options_path,
                selected: selected_filter_value(:brand), selected_label: selected_brand_label(selected_filter_value(:brand)),
                placeholder: t("search.any_brand") %>
        </div>

        <%# Small static enums: inline client-side combobox %>
        <% static_filter_fields.each do |field, opts| %>
          <div>
            <div class="filter-label"><%= opts[:label] %></div>
            <%= render "shared/combobox", name: field.to_s, options: opts[:options],
                  selected: params[field], placeholder: opts[:placeholder] %>
          </div>
        <% end %>

        <div>
          <div class="filter-label"><%= t("search.other") %></div>
          <label class="toggle"><%= check_box_tag :saltwater, "1", params[:saltwater].present? %><span class="track"><span class="knob"></span></span><%= t("search.saltwater_only") %></label>
        </div>
      </div>
      <div class="panel-foot">
        <a href="<%= lures_path %>" class="muted" style="font-size:14px"><%= t("search.clear_all") %></a>
        <button type="submit" class="btn btn-primary"><%= t("common.search") %></button>
      </div>
    <% end %>
  </div>
</div>
