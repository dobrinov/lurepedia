<header class="site-header">
  <div class="container">
    <a href="<%= localized_root_path %>" class="wordmark"><span class="lure">lure</span><span class="pedia">pedia</span></a>

    <nav class="main-nav">
      <%= link_to t("nav.lures"), lures_path, class: ("active" if controller_name == "lures") %>
      <%= link_to t("nav.species"), species_index_path, class: ("active" if controller_name == "species") %>
      <%= link_to t("nav.catches"), catches_path, class: ("active" if controller_name == "catches") %>
    </nav>

    <div class="header-right">
      <!-- Primary nav as a menu on small screens, where .main-nav is hidden -->
      <div class="dropdown nav-menu" data-controller="dropdown">
        <button class="nav-toggle" data-action="dropdown#toggle" data-dropdown-target="trigger" aria-expanded="false" aria-label="<%= t("nav.menu") %>">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"></path></svg>
        </button>
        <div class="dropdown-menu" data-dropdown-target="menu" hidden>
          <%= link_to t("nav.lures"), lures_path, class: ("active" if controller_name == "lures") %>
          <%= link_to t("nav.species"), species_index_path, class: ("active" if controller_name == "species") %>
          <%= link_to t("nav.catches"), catches_path, class: ("active" if controller_name == "catches") %>
        </div>
      </div>

      <!-- Language switcher: only for guests; signed-in users use their configured language -->
      <% unless signed_in? %>
        <div class="dropdown" data-controller="dropdown">
          <button class="lang-pill" data-action="dropdown#toggle" data-dropdown-target="trigger" aria-expanded="false" aria-label="<%= t("settings.language") %>">
            <%= country_flag(locale_country(I18n.locale), size: 22) %>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a1a1aa" stroke-width="2.2"><path d="m6 9 6 6 6-6"></path></svg>
          </button>
          <div class="dropdown-menu" data-dropdown-target="menu" hidden>
            <% available_locales_for_switcher.each do |loc, meta| %>
              <%= link_to url_for(locale: loc), class: "lang-item #{'active' if loc == I18n.locale}" do %>
                <%= country_flag(meta[:country], size: 22) %>
                <span><%= meta[:native] %></span>
                <% if loc == I18n.locale %><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" style="margin-left:auto"><path d="M20 6 9 17l-5-5"></path></svg><% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if signed_in? %>
        <div class="dropdown" data-controller="dropdown">
          <button class="avatar" data-action="dropdown#toggle" data-dropdown-target="trigger" aria-expanded="false" title="<%= current_user.name %>"><%= user_avatar(current_user) %></button>
          <div class="dropdown-menu" data-dropdown-target="menu" hidden>
            <div class="menu-head">
              <span class="avatar"><%= user_avatar(current_user) %></span>
              <div style="min-width:0">
                <div class="row" style="gap:6px"><strong style="font-size:14px"><%= current_user.name %></strong><span class="role-badge role-<%= current_user.role %>"><%= t("admin.#{current_user.role}") %></span></div>
                <div class="muted" style="font-size:12px"><%= current_user.email_address %></div>
              </div>
            </div>
            <div class="dropdown-divider"></div>
            <%= link_to t("catch.add_title"), new_catch_path %>
            <%= link_to t("dashboard.my_profile"), profile_path(current_user) %>
            <%= link_to t("settings.title"), profile_path(current_user, tab: "settings") %>
            <% if current_user.can_moderate? %>
              <div class="dropdown-divider"></div>
              <%= link_to t("moderation.title"), moderation_index_path %>
              <% if current_user.admin? %><%= link_to t("admin.title"), admin_root_path %><% end %>
            <% end %>
            <div class="dropdown-divider"></div>
            <%= button_to t("auth.sign_out"), session_path, method: :delete, style: "color:var(--danger)" %>
          </div>
        </div>
      <% else %>
        <%= link_to t("auth.sign_in"), new_session_path, class: "btn btn-sm" %>
      <% end %>
    </div>
  </div>
</header>
