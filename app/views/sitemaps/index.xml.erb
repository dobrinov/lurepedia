<%= '<?xml version="1.0" encoding="UTF-8"?>'.html_safe %>
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <% @locales.each do |loc| %>
  <sitemap>
    <loc><%= locale_sitemap_url(locale: loc) %></loc>
    <% if @lastmod %>
    <lastmod><%= @lastmod.utc.iso8601 %></lastmod>
    <% end %>
  </sitemap>
  <% end %>
</sitemapindex>
