<%= '<?xml version="1.0" encoding="UTF-8"?>'.html_safe %>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:xhtml="http://www.w3.org/1999/xhtml">
  <%
    entries = []
    @static_paths.each { |name| entries << ->(loc) { public_send("#{name}_url", locale: loc) } }
    @lures.each { |r| entries << ->(loc) { lure_url(r, locale: loc) } }
    @species.each { |r| entries << ->(loc) { species_url(r, locale: loc) } }
    @brands.each { |r| entries << ->(loc) { brand_url(r, locale: loc) } }
  %>
  <% entries.each do |builder| %>
    <url>
      <loc><%= builder.call(I18n.default_locale) %></loc>
      <% @locales.each do |loc| %>
        <xhtml:link rel="alternate" hreflang="<%= loc %>" href="<%= builder.call(loc) %>"/>
      <% end %>
      <xhtml:link rel="alternate" hreflang="x-default" href="<%= builder.call(I18n.default_locale) %>"/>
    </url>
  <% end %>
</urlset>
