<% content_for :title, @lure.title %>
<% content_for :head do %>
  <meta name="description" content="<%= "#{@lure.title}: #{@lure.description}".truncate(155) %>">
  <%= tag.script type: "application/ld+json" do %>
    <%= raw({ "@context": "https://schema.org", "@type": "Product", name: @lure.title, brand: @lure.brand.name, category: lure_type_name(@lure.lure_type), description: @lure.description }.to_json) %>
  <% end %>
<% end %>

<% dv = @selected_variant %>

<%= render "shared/pending_review", record: @lure %>

<div class="container" style="padding-top:24px"
     data-controller="variant-stage"
     data-variant-stage-base-path-value="<%= lure_path(@lure) %>"
     data-variant-stage-tabs-value="<%= %w[caught buy history variations].to_json %>">

  <nav class="muted" style="font-size:13px;margin-bottom:16px">
    <%= link_to t("nav.lures"), lures_path %> ›
    <%= link_to @lure.brand.name, brand_path(@lure.brand) %> ›
    <span><%= @lure.model %></span>
  </nav>

  <!-- Hero: preview image + color selector -->
  <div class="lure-hero">
    <div class="lure-stage">
      <span class="lure-stage-chip">
        <span data-variant-stage-target="chipName"><%= dv&.name %></span>
        <span class="uv-badge" data-variant-stage-target="chipUv" <%= "hidden" unless dv&.uv_glow %>>UV</span>
      </span>
      <% if dv&.photo&.attached? %>
        <img data-variant-stage-target="stageImage" src="<%= url_for(dv.photo.variant(resize_to_limit: [ 760, 580 ])) %>" alt="<%= @lure.title %>">
        <div class="lure-stage-glyph" data-variant-stage-target="stageGlyph" hidden><%= render "shared/lure_glyph" %></div>
      <% else %>
        <img data-variant-stage-target="stageImage" hidden alt="<%= @lure.title %>">
        <div class="lure-stage-glyph" data-variant-stage-target="stageGlyph"><%= render "shared/lure_glyph" %></div>
      <% end %>
    </div>

    <div class="stack" style="gap:14px">
      <div class="card-brand"><%= @lure.brand.name %></div>
      <h1 style="font-size:32px;font-weight:800;letter-spacing:-.03em;line-height:1"><%= @lure.model %></h1>

      <div class="chips">
        <span class="tag"><%= lure_type_name(@lure.lure_type) %></span>
        <span class="tag"><%= lure_action_label(@lure.dominant_action) %></span>
        <span class="tag"><%= water_name(@lure.water_summary) %></span>
      </div>

      <% if @variants.many? %>
        <div>
          <div class="overline" style="margin-bottom:8px"><%= t("lure.browse_colors") %></div>
          <div class="color-tiles">
            <% @variants.each do |v| %>
              <span class="tooltip color-tile-tip" data-tooltip="<%= v.name %>">
                <button type="button" class="color-tile"
                        data-variant-stage-target="chip"
                        data-action="variant-stage#select"
                        data-default="<%= v == @selected_variant %>"
                        data-color-id="<%= v.id %>"
                        data-color-slug="<%= v.to_color_param %>"
                        data-name="<%= v.name %>"
                        data-uv="<%= v.uv_glow %>"
                        <% if v.photo.attached? %>data-photo-url="<%= url_for(v.photo.variant(resize_to_limit: [ 760, 580 ])) %>"<% end %>>
                  <% if v.photo.attached? %>
                    <%= image_tag v.photo.variant(resize_to_fill: [ 120, 120 ]), alt: v.name %>
                  <% else %>
                    <span class="color-tile-empty"><%= render "shared/lure_glyph" %></span>
                  <% end %>
                  <% if v.uv_glow %><span class="uv-badge color-tile-uv">UV</span><% end %>
                </button>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="row" style="flex-wrap:wrap;gap:10px">
        <% if signed_in? %>
          <%= link_to edit_affordance_label(@lure), edit_lure_path(@lure), class: "btn" %>
        <% else %>
          <%= link_to edit_affordance_label, new_session_path, class: "btn" %>
        <% end %>
        <%= render "shared/favorite_button", favoritable: @lure %>
        <% if @lure.action_video_url.present? %>
          <%= link_to safe_join([ t("lure.watch_video"), external_link_icon ]), @lure.action_video_url, class: "muted", style: "font-size:13px;align-self:center;text-decoration:underline", target: "_blank", rel: "noopener" %>
        <% end %>
      </div>

      <% if @lure.description.present? %><p class="muted" style="margin-top:4px;white-space:pre-line"><%= @lure.description %></p><% end %>
    </div>
  </div>

  <!-- Tabs -->
  <div style="margin-top:48px">
    <% color = @selected_variant&.to_color_param %>
    <% tabs = [
         [ t("lure.tab_variations"), lure_tab_path(@lure, tab: "variations", color: color), @tab == "variations" ],
         [ t("lure.tab_caught"), lure_tab_path(@lure, tab: "caught", color: color), @tab == "caught" ],
         [ t("lure.tab_buy"), lure_tab_path(@lure, tab: "buy", color: color), @tab == "buy" ],
         [ t("lure.tab_history"), lure_tab_path(@lure, tab: "history", color: color), @tab == "history" ]
       ] %>
    <%= render "shared/tabs", tabs: tabs %>

    <% case @tab %>
    <% when "caught" %>
      <% if @catches.any? %>
        <div class="grid-catches">
          <% @catches.each do |c| %><%= render "shared/catch_card", catch: c %><% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <h3><%= t("lure.be_first") %></h3>
          <p><%= t("home.hero_sub") %></p>
          <% if signed_in? %>
            <%= link_to t("lure.add_catch"), new_catch_path(lure: @lure.slug), class: "btn btn-primary" %>
          <% else %>
            <%= link_to t("lure.add_catch"), new_session_path, class: "btn btn-primary" %>
          <% end %>
        </div>
      <% end %>
    <% when "variations" %>
      <% if @variants.any? %>
        <% @variants.each do |v| %>
          <div class="variation-table" data-variant-stage-target="buildsTable" data-color-id="<%= v.id %>" <%= "hidden" unless v == @selected_variant %>>
            <% if @builds.any? %>
              <div class="card">
                <table class="lb-table">
                  <thead><tr><th><%= t("lure.build") %></th><th><%= t("lure.size") %></th><th><%= t("lure.weight") %></th><th><%= t("lure.depth") %></th><th><%= t("lure.buoyancy") %></th><th><%= t("lure.water") %></th><th></th></tr></thead>
                  <tbody>
                    <% @builds.each do |b| %>
                      <tr>
                        <td style="font-weight:600"><%= b.name %></td>
                        <td><%= fmt_size_mm(b.length_mm) || t("common.none") %></td>
                        <td><%= fmt_weight(b.weight_g) || t("common.none") %></td>
                        <td><%= fmt_depth(b.depth_min_cm, b.depth_max_cm) || t("common.none") %></td>
                        <td><%= lure_action_label(b.action) %></td>
                        <td><%= water_name(b.water) %></td>
                        <td style="text-align:right;white-space:nowrap">
                          <% if signed_in? %>
                            <%= link_to t("lure.add_catch"), new_catch_path(lure: @lure.slug, variant_id: v.id, build_id: b.id), class: "btn btn-sm" %>
                          <% else %>
                            <%= link_to t("lure.add_catch"), new_session_path, class: "btn btn-sm" %>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <div class="card card-pad"><p class="muted" style="font-size:13px"><%= t("catch.no_builds") %></p></div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="card card-pad"><p class="muted" style="font-size:13px"><%= t("lure.be_first") %></p></div>
      <% end %>
    <% when "buy" %>
      <% if @buy_links.any? %>
        <div class="card card-tooltips">
          <table class="lb-table">
            <tbody>
              <% @buy_links.each do |bl| %>
                <% target_url = bl.url.presence || bl.shop.url.presence %>
                <% href = target_url ? "https://#{target_url.sub(%r{\Ahttps?://}, '')}" : shops_path %>
                <% countries = bl.shop.ships_to_countries %>
                <tr>
                  <td>
                    <span class="row" style="gap:8px">
                      <%= link_to safe_join([ bl.shop.name, external_link_icon ]), href, target: "_blank", rel: "noopener nofollow", style: "font-weight:600" %>
                      <% if bl.shop.promoted? %><span class="badge badge-promoted"><%= t("common.promoted") %></span><% end %>
                    </span>
                  </td>
                  <td style="text-align:right">
                    <% if bl.shop.ships_worldwide? %>
                      <span class="row" style="gap:6px;justify-content:flex-end;align-items:center">
                        <%= worldwide_flag(size: 18) %><span class="muted" style="font-size:12.5px"><%= t("shop.worldwide") %></span>
                      </span>
                    <% elsif countries.any? %>
                      <span class="row" style="gap:5px;justify-content:flex-end;flex-wrap:wrap">
                        <% countries.each do |code| %><span class="tooltip" data-tooltip="<%= country_name(code) %>" tabindex="0" style="display:inline-flex"><%= country_flag(code, size: 18) %></span><% end %>
                      </span>
                    <% else %>
                      <span class="muted" style="font-size:12.5px"><%= t("shop.ships_to_unknown") %></span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="card card-pad">
          <p class="muted" style="font-size:13px"><%= t("buy_link.empty") %></p>
        </div>
      <% end %>
      <% if signed_in? %>
        <%= render "lures/buy_link_form", lure: @lure %>
      <% else %>
        <p class="muted" style="font-size:13px;margin-top:16px"><%= link_to t("buy_link.add"), new_session_path %></p>
      <% end %>
    <% when "history" %>
      <% revisions = @lure.revisions.applied.newest_first.to_a %>
      <% if revisions.any? %>
        <div class="card">
          <table class="lb-table">
            <thead><tr><th><%= t("provenance.col_change") %></th><th><%= t("provenance.col_contributor") %></th><th><%= t("provenance.col_date") %></th></tr></thead>
            <tbody>
              <% revisions.each do |rev| %>
                <tr>
                  <td>
                    <% if rev.edit? %>
                      <%= link_to t("provenance.edited"), revision_path(rev), style: "font-weight:600" %>
                    <% else %>
                      <%= rev.summary %>
                    <% end %>
                  </td>
                  <td>
                    <% if rev.user %>
                      <%= link_to rev.user.name, profile_path(rev.user) %>
                    <% else %>
                      <%= t("common.none") %>
                    <% end %>
                  </td>
                  <td style="white-space:nowrap"><%= l(rev.created_at, format: :long) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="card card-pad">
          <p class="muted" style="font-size:13px"><%= t("provenance.created") %></p>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
