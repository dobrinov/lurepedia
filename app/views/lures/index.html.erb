<% content_for :head, tag.meta(name: "robots", content: "index,follow") %>
<div class="container">
  <div class="page-head">
    <div>
      <h1><%= t("lure.title") %></h1>
    </div>
    <%= link_to t("lure.add"), new_lure_path, class: "btn btn-sm" %>
  </div>

  <div class="page-search-row">
    <%= render "lures/search" %>
  </div>

  <!-- Active filter pills -->
  <% if @filter.active_pills.any? %>
    <div class="chips" style="margin-bottom:18px">
      <% @filter.active_pills.each do |key, label| %>
        <span class="filter-pill"><%= label %>
          <%= link_to "×", url_for(request.query_parameters.except(key.to_s, "page")) %>
        </span>
      <% end %>
      <%= link_to t("search.clear_all"), lures_path, class: "muted", style: "font-size:13px" %>
    </div>
  <% end %>

  <% if @lures.any? %>
    <div class="grid-cards">
      <% @lures.each do |lure| %>
        <%= render "shared/lure_card", lure: lure %>
      <% end %>
    </div>
    <%= render "shared/pagination", page: @page %>
  <% elsif @filter.any? %>
    <div class="empty-state">
      <h3><%= t("lure.no_matches") %></h3>
      <p><%= t("lure.no_matches_sub") %></p>
      <div class="empty-state-actions">
        <%= link_to t("search.clear_all"), lures_path, class: "btn" %>
        <%= link_to t("lure.add"), new_lure_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% else %>
    <div class="empty-state">
      <h3><%= t("lure.empty_title") %></h3>
      <p><%= t("home.hero_sub") %></p>
      <%= link_to t("lure.add"), new_lure_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
