<%= render layout: "shared/filter_panel",
      locals: { url: lures_path, placeholder: t("lure.search_placeholder") } do %>
  <%# Large collections: server-backed, paginated, infinite-scroll comboboxes %>
  <div>
    <div class="filter-label"><%= t("nav.species") %></div>
    <%= render "shared/async_combobox", name: "species", url: species_options_path,
          selected: selected_filter_value(:species), selected_label: selected_species_label(selected_filter_value(:species)),
          placeholder: t("search.any_species") %>
  </div>
  <div>
    <div class="filter-label"><%= t("lure.brand") %></div>
    <%= render "shared/async_combobox", name: "brand", url: brand_options_path,
          selected: selected_filter_value(:brand), selected_label: selected_brand_label(selected_filter_value(:brand)),
          placeholder: t("search.any_brand") %>
  </div>

  <%# Small static enums: inline client-side combobox %>
  <% static_filter_fields.each do |field, opts| %>
    <div>
      <div class="filter-label"><%= opts[:label] %></div>
      <%= render "shared/combobox", name: field.to_s, options: opts[:options],
            selected: params[field], placeholder: opts[:placeholder] %>
    </div>
  <% end %>

  <%# Build-spec ranges, in the units lures are catalogued in (mm / g) %>
  <div>
    <div class="filter-label"><%= t("lure.size") %> (mm)</div>
    <div class="range-inputs">
      <%= number_field_tag :length_min, selected_filter_value(:length_min), min: 0, class: "input",
            placeholder: t("search.min"), aria: { label: "#{t('lure.size')} #{t('search.min')}" } %>
      <span class="muted">–</span>
      <%= number_field_tag :length_max, selected_filter_value(:length_max), min: 0, class: "input",
            placeholder: t("search.max"), aria: { label: "#{t('lure.size')} #{t('search.max')}" } %>
    </div>
  </div>
  <%# Weight follows the viewer's unit preference; the unit rides the URL so
      redisplayed (or shared) filter values keep the unit they were typed in %>
  <% weight_unit = selected_weight_filter_unit %>
  <div>
    <div class="filter-label"><%= t("lure.weight") %> (<%= t("units.#{weight_unit}") %>)</div>
    <%= hidden_field_tag :weight_unit, weight_unit if weight_unit != "g" %>
    <div class="range-inputs">
      <%= number_field_tag :weight_min, selected_filter_value(:weight_min), min: 0, step: "any", class: "input",
            placeholder: t("search.min"), aria: { label: "#{t('lure.weight')} #{t('search.min')}" } %>
      <span class="muted">–</span>
      <%= number_field_tag :weight_max, selected_filter_value(:weight_max), min: 0, step: "any", class: "input",
            placeholder: t("search.max"), aria: { label: "#{t('lure.weight')} #{t('search.max')}" } %>
    </div>
  </div>
  <%# Per-color finish flags — presence-only toggles (on = require it) %>
  <div>
    <div class="filter-label"><%= t("lure.finish") %></div>
    <div class="stack" style="gap:8px">
      <label class="toggle"><%= check_box_tag :glow, "1", selected_filter_value(:glow) %><span class="track"><span class="knob"></span></span><%= t("lure.glow") %></label>
      <label class="toggle"><%= check_box_tag :uv, "1", selected_filter_value(:uv) %><span class="track"><span class="knob"></span></span><%= t("lure.uv") %></label>
    </div>
  </div>
  <%# Technique is multi-valued — a lure matches any selected technique. %>
  <% technique_selected = params[:technique].is_a?(Array) ? params[:technique] : params[:technique].to_s.split(",") %>
  <div>
    <div class="filter-label"><%= t("lure.techniques") %></div>
    <%= render "shared/multiselect", name: "technique",
          options: Technique.all.sort_by(&:key).map { |tech| { value: tech.key, label: technique_name(tech) } },
          selected: technique_selected, placeholder: t("search.any_techniques") %>
  </div>
<% end %>
